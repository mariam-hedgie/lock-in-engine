{
  "manifest_version": 3,
  "name": "Lock-In Engine",
  "version": "1.0",
  "description": "Reports active tab URL to Lock-In Engine for focus tracking.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:27182/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  }
}
